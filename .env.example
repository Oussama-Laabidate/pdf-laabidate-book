# Required in every environment. Use long, unique values.
ADMIN_CODE=replace-with-a-strong-admin-code
SESSION_SECRET=replace-with-at-least-32-random-characters
NEXT_PUBLIC_SITE_URL=https://your-public-domain.example

# Optional Google Gemini AI for PDF summaries, SEO metadata, and public catalog questions.
# You can also save this from /admin; the admin value is encrypted with SESSION_SECRET.
GEMINI_API_KEY=replace-with-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash

# Optional durable statistics storage for Vercel.
# If these are empty, local development writes content/stats.json.
# KV_REST_API_URL=https://...
# KV_REST_API_TOKEN=...
# CATALOG_STATS_KEY=catalog_stats

# Local development reads and writes project files.
CATALOG_STORAGE_MODE=local

# Vercel production reads PDF files and updates the manifest in a private GitHub repository.
# CATALOG_STORAGE_MODE=github
# GITHUB_REPOSITORY=owner/repository
# GITHUB_CONTENT_BRANCH=main
# GITHUB_CONTENT_TOKEN=github-fine-grained-token
