# Required in every environment. Use long, unique values.
ADMIN_CODE=replace-with-a-strong-admin-code
SESSION_SECRET=replace-with-at-least-32-random-characters

# Local development reads and writes project files.
CATALOG_STORAGE_MODE=local

# Vercel production reads PDF files and updates the manifest in a private GitHub repository.
# CATALOG_STORAGE_MODE=github
# GITHUB_REPOSITORY=owner/repository
# GITHUB_CONTENT_BRANCH=main
# GITHUB_CONTENT_TOKEN=github-fine-grained-token
